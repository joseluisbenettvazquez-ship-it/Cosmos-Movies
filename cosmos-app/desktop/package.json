{
  "name": "cosmos-desktop",
  "version": "1.0.0",
  "description": "Cosmos - cine compartido",
  "main": "main.js",
  "scripts": {
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.cosmos.cine",
    "productName": "Cosmos",
    "files": ["main.js", "index.html"],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.entertainment"
    },
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "dist"
    }
  }
}
